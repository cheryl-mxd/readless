# Copy to .env and fill in your keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
DASHSCOPE_API_KEY=...   # Qwen / Alibaba Cloud

# Optional defaults
DEFAULT_PROVIDER=qwen
DEFAULT_LANGUAGE=Simplified-Chinese
OUTPUT_TEMPLATE=obsidian
SINGLE_PASS_CONTENT_LIMIT=12000

# Optional Docker deployment settings
WEB_PORT=3000
API_PORT=8000
API_INTERNAL_URL=http://api:8000
READLESS_WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
